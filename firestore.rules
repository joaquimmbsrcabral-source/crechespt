rules_version = '2';

// Regras de segurança Firestore — CrechesPT
// Modelo: cada utilizador tem o seu próprio espaço; ninguém vê os dados de mais ninguém.
service cloud.firestore {
  match /databases/{database}/documents {

    // Espaço pessoal de cada utilizador autenticado
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == uid;
    }

    // Captura de interesse de creches via página /para-creches
    // Qualquer pessoa pode submeter (create), ninguém pode ler/editar/apagar pela app
    // (administra-se através do Firebase Console).
    match /creche_interest/{id} {
      allow create: if
           request.resource.data.keys().hasOnly(["nome","tipo","distrito","email","telefone","criancas","mensagem","source","user_agent","lang","ts"])
        && request.resource.data.nome is string && request.resource.data.nome.size() <= 200
        && request.resource.data.email is string && request.resource.data.email.size() <= 120
        && request.resource.data.tipo is string && request.resource.data.tipo.size() <= 20
        && request.resource.data.distrito is string && request.resource.data.distrito.size() <= 60;
      allow read, update, delete: if false;
    }

    // Feedback de utilizadores autenticados
    match /feedback/{id} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 2000;
      allow read, update, delete: if false;
    }

    // Tudo o resto bloqueado
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
