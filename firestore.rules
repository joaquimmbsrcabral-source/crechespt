rules_version = '2';

// Regras de segurança Firestore — Creches.app
// Modelo: cada utilizador tem o seu próprio espaço; admins têm leitura agregada.
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: verifica se o utilizador é admin (existe doc em admins/{uid})
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Documento de perfil de cada utilizador (criado/atualizado no login)
    // O próprio pode ler/escrever; admin pode ler (para listar utilizadores).
    match /users/{uid} {
      allow read:  if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Subcoleções privadas de cada utilizador (creches guardadas, pipeline, etc.)
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Documentos admins: cria-se manualmente no Firebase Console.
    // Cada utilizador consegue ler o seu próprio para se auto-detetar como admin.
    match /admins/{uid} {
      allow read:  if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Newsletter — subscritores de updates do creches.app
    // Qualquer pessoa pode subscrever; só admin lê e gere.
    match /newsletter_subscribers/{id} {
      allow create: if
           request.resource.data.keys().hasOnly(['email', 'source', 'lang', 'ts'])
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 120
        && request.resource.data.email.matches('[^\\s@]+@[^\\s@]+\\.[^\\s@]+');
      allow read:   if isAdmin();
      allow update, delete: if isAdmin();
    }

    // Captura de interesse de creches via página /para-creches
    // Qualquer pessoa pode submeter (create); só admin lê.
    match /creche_interest/{id} {
      allow create: if
           request.resource.data.keys().hasOnly(["nome","tipo","distrito","email","telefone","criancas","mensagem","morada","idades","idade_min_meses","idade_max_meses","website","horario","source","user_agent","lang","ts"])
        && request.resource.data.nome is string && request.resource.data.nome.size() <= 200
        && request.resource.data.email is string && request.resource.data.email.size() <= 120
        && request.resource.data.tipo is string && request.resource.data.tipo.size() <= 20
        && request.resource.data.distrito is string && request.resource.data.distrito.size() <= 60
        && request.resource.data.morada is string && request.resource.data.morada.size() <= 200
        && (!('website' in request.resource.data) ||
            (request.resource.data.website is string && request.resource.data.website.size() <= 200))
        && (!('horario' in request.resource.data) ||
            (request.resource.data.horario is string && request.resource.data.horario.size() <= 120))
        && (!('mensagem' in request.resource.data) ||
            (request.resource.data.mensagem is string && request.resource.data.mensagem.size() <= 1000));
      allow read:   if isAdmin();
      allow update: if isAdmin();  // marca como aprovado/rejeitado
      allow delete: if false;
    }

    // Feedback de utilizadores autenticados
    // O próprio cria; só admin lê.
    match /feedback/{id} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['uid','email','displayName','category','message','url','user_agent','ts'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 2000;
      allow read:   if isAdmin();
      allow update, delete: if false;
    }

    // Reports de erros em creches (idade, telefone, encerrada, etc.)
    // Qualquer utilizador autenticado cria; só admin lê e atualiza.
    match /creche_reports/{id} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['uid','email','creche_id','creche_name','report_type','claimed_age','correction','note','current_tipo','current_min','current_max','current_telefone','url','ts'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.creche_name is string
        && request.resource.data.creche_name.size() <= 200
        && request.resource.data.claimed_age is string
        && request.resource.data.claimed_age.size() <= 30
        && request.resource.data.note is string
        && request.resource.data.note.size() <= 600;
      allow read:   if isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Override de creches existentes (corrige idades, telefone, etc.)
    // Read público — a app aplica os overrides ao carregar.
    // Write só admin (via admin panel).
    match /creche_overrides/{cid} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // Creches extra (não estavam no dataset original; submetidas via /para-creches e aprovadas).
    // Read público; write só admin.
    match /creche_extras/{eid} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // Stats diários (page views agregados, sem dados pessoais)
    // Qualquer pessoa pode criar/incrementar; só admin lê.
    match /daily_stats/{date} {
      allow read: if isAdmin();
      allow create: if
        request.resource.data.keys().hasOnly(['app_views','site_views','updated_at'])
        && (!('app_views' in request.resource.data) || (request.resource.data.app_views is int && request.resource.data.app_views >= 0 && request.resource.data.app_views <= 5))
        && (!('site_views' in request.resource.data) || (request.resource.data.site_views is int && request.resource.data.site_views >= 0 && request.resource.data.site_views <= 5));
      allow update: if
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['app_views','site_views','updated_at'])
        && (!('app_views' in request.resource.data) || !('app_views' in resource.data)
            || (request.resource.data.app_views >= resource.data.app_views && request.resource.data.app_views <= resource.data.app_views + 5))
        && (!('site_views' in request.resource.data) || !('site_views' in resource.data)
            || (request.resource.data.site_views >= resource.data.site_views && request.resource.data.site_views <= resource.data.site_views + 5));
      allow delete: if false;
    }

    // Pedidos de remoção de creche (RGPD / direito ao esquecimento)
    // Qualquer pessoa (autenticada ou não) pode pedir; só admin lê.
    match /creche_removals/{id} {
      allow create: if
           request.resource.data.keys().hasOnly(['creche_id','creche_name','relationship','requester_email','reason','url','user_agent','uid','ts'])
        && request.resource.data.creche_name is string
        && request.resource.data.creche_name.size() <= 200
        && request.resource.data.relationship is string
        && request.resource.data.relationship.size() <= 30
        && request.resource.data.requester_email is string
        && request.resource.data.requester_email.size() <= 120
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 800;
      allow read:   if isAdmin();
      allow update, delete: if false;
    }

    // ─── Vagas em tempo real (Onda 29 — Jun 2026) ───
    // Dual-source: creches reportam (verificado por email) e pais reportam
    // anonimamente. Auto-expiração via TTL no campo expires_at (7 dias).
    match /vagas/{vagaId} {
      // Leitura pública — qualquer um pode ver vagas activas
      allow read: if true;

      // Qualquer pessoa pode criar (anónimo ou autenticado)
      // Validação básica: campos obrigatórios, source válido, tamanhos máx.
      allow create: if
           request.resource.data.keys().hasOnly(['creche_id', 'nome_creche', 'source', 'verificado', 'idades', 'notas', 'reportado_em', 'expires_at', 'reportado_por'])
        && request.resource.data.keys().hasAll(['creche_id', 'source', 'reportado_em', 'expires_at'])
        && request.resource.data.source in ['creche', 'pai']
        && request.resource.data.verificado == false
        && request.resource.data.expires_at is timestamp
        && request.resource.data.expires_at <= request.time + duration.value(8, 'd')
        && request.resource.data.creche_id is string
        && request.resource.data.creche_id.size() < 100
        && request.resource.data.creche_id.size() > 0
        && (!('notas' in request.resource.data) ||
            (request.resource.data.notas is string &&
             request.resource.data.notas.size() < 280))
        && (!('nome_creche' in request.resource.data) ||
            (request.resource.data.nome_creche is string &&
             request.resource.data.nome_creche.size() <= 200))
        && (!('idades' in request.resource.data) ||
            (request.resource.data.idades is list &&
             request.resource.data.idades.size() <= 5));

      // Só admin pode actualizar (confirmar vaga, etc.) ou apagar
      allow update, delete: if isAdmin();

      // Fase 0 (0.2) — Gestor da creche publica vaga VERIFICADA no doc determinístico
      // "painel_<creche_id>". Fonte única: o mesmo doc alimenta badges e filtro "Com vaga".
      allow create, update: if request.auth != null
        && isManagerOf(request.resource.data.creche_id)
        && vagaId == 'painel_' + request.resource.data.creche_id
        && request.resource.data.keys().hasOnly(['creche_id', 'nome_creche', 'source', 'verificado', 'idades', 'notas', 'reportado_em', 'expires_at', 'reportado_por'])
        && request.resource.data.keys().hasAll(['creche_id', 'source', 'reportado_em', 'expires_at'])
        && request.resource.data.source == 'painel'
        && request.resource.data.verificado == true
        && request.resource.data.expires_at is timestamp
        && request.resource.data.expires_at <= request.time + duration.value(32, 'd')
        && request.resource.data.creche_id is string
        && request.resource.data.creche_id.size() > 0
        && request.resource.data.creche_id.size() < 100
        && (!('nome_creche' in request.resource.data) ||
            (request.resource.data.nome_creche is string &&
             request.resource.data.nome_creche.size() <= 200))
        && (!('notas' in request.resource.data) ||
            (request.resource.data.notas is string &&
             request.resource.data.notas.size() < 280))
        && (!('idades' in request.resource.data) ||
            (request.resource.data.idades is list &&
             request.resource.data.idades.size() <= 5));
      // Gestor pode apagar a própria vaga do painel (desligou todos os toggles)
      allow delete: if request.auth != null
        && resource != null
        && vagaId == 'painel_' + resource.data.creche_id
        && isManagerOf(resource.data.creche_id);
    }

    // ─── Creche Views (Onda 36 #3 — Jul 2026) ───
    // Contador anónimo de visualizações por creche por dia, para dashboard do painel.
    // Estrutura: creche_views/{crecheId}/days/{yyyy-mm-dd} { count, ts }
    match /creche_views/{crecheId}/days/{day} {
      // Leitura pública (mostrar na página pública ou no painel)
      allow read: if true;
      // Criar/incrementar sem auth — só o campo count com increment(1) e ts serverTimestamp
      allow create: if request.resource.data.keys().hasOnly(['count','ts'])
        && request.resource.data.count is int
        && request.resource.data.count >= 1 && request.resource.data.count <= 3;
      allow update: if request.resource.data.keys().hasOnly(['count','ts'])
        && request.resource.data.count is int
        && request.resource.data.count > resource.data.count
        && request.resource.data.count <= resource.data.count + 3;
    }
    // (bloqueia acesso ao documento intermédio)
    match /creche_views/{crecheId} {
      allow read, write: if false;
    }

    // ─── Creche Feliz Reports (Onda 32 — Jun 2026) ───
    // Pais e creches podem reportar adesão ao programa Creche Feliz.
    // Sem expiração (adesão é estável). Admin pode marcar valido=false
    // se for falso positivo.
    match /creche_feliz_reports/{reportId} {
      // Leitura pública — qualquer um pode ver
      allow read: if true;

      // Qualquer pessoa pode criar (anónimo ou autenticado)
      allow create: if
           request.resource.data.keys().hasOnly(['creche_id', 'nome_creche', 'source', 'verificado', 'valido', 'reportado_em', 'reportado_por'])
        && request.resource.data.keys().hasAll(['creche_id', 'source', 'reportado_em'])
        && request.resource.data.source in ['creche', 'pai']
        && request.resource.data.verificado == false
        && request.resource.data.creche_id is string
        && request.resource.data.creche_id.size() < 100
        && request.resource.data.creche_id.size() > 0
        && (!('nome_creche' in request.resource.data) ||
            (request.resource.data.nome_creche is string &&
             request.resource.data.nome_creche.size() <= 200))
        && request.resource.data.valido == true;

      // Só admin actualiza (marca falso positivo) ou apaga
      allow update, delete: if isAdmin();
    }

    // ═══════════════ CONTAS DE CRECHES (painel) ═══════════════

    // Helper: o utilizador é o gestor aprovado desta creche?
    function isManagerOf(cid) {
      return request.auth != null
        && exists(/databases/$(database)/documents/creche_managers/$(request.auth.uid))
        && get(/databases/$(database)/documents/creche_managers/$(request.auth.uid)).data.creche_id == cid;
    }

    // Pedidos de acesso ("a minha creche é esta") — aprovados manualmente no /admin
    match /creche_claims/{id} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(['uid','email','creche_id','creche_nome','nome_responsavel','cargo','telefone','mensagem','status','ts'])
        && request.resource.data.status == 'pending'
        && request.resource.data.creche_id is string
        && request.resource.data.creche_id.size() > 0
        && request.resource.data.creche_id.size() < 100
        && request.resource.data.creche_nome is string
        && request.resource.data.creche_nome.size() <= 200
        && request.resource.data.nome_responsavel is string
        && request.resource.data.nome_responsavel.size() <= 120
        && request.resource.data.telefone is string
        && request.resource.data.telefone.size() <= 30;
      allow read: if request.auth != null
        && (resource.data.uid == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // Quem gere que creche — escrito APENAS pelo admin ao aprovar um claim
    match /creche_managers/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }

    // Perfil editável da creche — leitura PÚBLICA (alimenta fichas e /app)
    match /creche_profiles/{cid} {
      allow read: if true;
      allow create, update: if (isManagerOf(cid) || isAdmin())
        && request.resource.data.keys().hasOnly(['descricao','horario','mensalidade_min','mensalidade_max','creche_feliz','vagas','contacto_email','contacto_telefone','website','fotos','updated_at','updated_by'])
        && (!('descricao' in request.resource.data) ||
            (request.resource.data.descricao is string && request.resource.data.descricao.size() <= 1500))
        && (!('horario' in request.resource.data) ||
            (request.resource.data.horario is string && request.resource.data.horario.size() <= 120))
        && (!('website' in request.resource.data) ||
            (request.resource.data.website is string && request.resource.data.website.size() <= 200))
        && (!('contacto_email' in request.resource.data) ||
            (request.resource.data.contacto_email is string && request.resource.data.contacto_email.size() <= 120))
        && (!('contacto_telefone' in request.resource.data) ||
            (request.resource.data.contacto_telefone is string && request.resource.data.contacto_telefone.size() <= 30))
        && (isAdmin() || !('updated_by' in request.resource.data) || request.resource.data.updated_by == request.auth.uid)
        // Fotos publicadas: só o admin altera (aprovação); gestor não mexe neste campo
        && (isAdmin()
            || !('fotos' in request.resource.data)
            || (resource != null && 'fotos' in resource.data && request.resource.data.fotos == resource.data.fotos));
      allow delete: if isAdmin();
    }

    // Fotos submetidas pelas creches — ficam pendentes até aprovação no /admin
    match /creche_fotos/{id} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && isManagerOf(request.resource.data.creche_id)
        && request.resource.data.keys().hasOnly(['creche_id','uid','url','legenda','status','ts'])
        && request.resource.data.status == 'pending'
        && request.resource.data.url is string
        && request.resource.data.url.size() <= 500
        && (!('legenda' in request.resource.data) ||
            (request.resource.data.legenda is string && request.resource.data.legenda.size() <= 140));
      allow read: if request.auth != null
        && (resource.data.uid == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // Tudo o resto bloqueado
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
